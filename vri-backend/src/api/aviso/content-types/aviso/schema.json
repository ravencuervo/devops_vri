        },
        "imagen": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "enlace": {
            "type": "string"
        },
        "textoBoton": {
            "type": "string"
        },
        "activo": {
            "type": "boolean",
            "default": false,
            "required": true
        }
    }
}