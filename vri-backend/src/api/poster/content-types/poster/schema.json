{
    "kind": "collectionType",
    "collectionName": "posters",
    "info": {
        "singularName": "poster",
        "pluralName": "posters",
        "displayName": "Poster Científico",
        "description": "Galería de posters destacados y premiados del VRI"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "titulo": {
            "type": "string",
            "required": true
        },
        "autor": {
            "type": "string",
            "required": true
        },
        "facultad": {
            "type": "string"
        },
        "evento": {
            "type": "string"
        },
        "puesto": {
            "type": "string"
        },
        "anio": {
            "type": "string"
        },
        "categoria": {
            "type": "string"
        },
        "imagen": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ],
            "required": true
        },
        "es_destacado": {
            "type": "boolean",
            "default": false
        }
    }
}