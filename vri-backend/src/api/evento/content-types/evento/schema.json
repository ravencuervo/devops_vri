{
    "kind": "collectionType",
    "collectionName": "eventos",
    "info": {
        "singularName": "evento",
        "pluralName": "eventos",
        "displayName": "Evento",
        "description": "Agenda de actividades y eventos del VRI"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "titulo": {
            "type": "string",
            "required": true
        },
        "descripcion": {
            "type": "blocks"
        },
        "fecha": {
            "type": "datetime",
            "required": true
        },
        "lugar": {
            "type": "string"
        },
        "ponente": {
            "type": "string"
        },
        "banner": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "link_registro": {
            "type": "string"
        },
        "link_interes": {
            "type": "string"
        },
        "tipo": {
            "type": "string"
        },
        "estado": {
            "type": "enumeration",
            "enum": [
                "Próximo",
                "En curso",
                "Finalizado"
            ],
            "default": "Próximo"
        },
        "etiquetas": {
            "type": "string"
        }
    }
}