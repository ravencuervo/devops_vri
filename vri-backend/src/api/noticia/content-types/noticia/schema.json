{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "Noticia"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string"
    },
    "categoria": {
      "type": "string"
    },
    "fecha": {
      "type": "date"
    },
    "contenido": {
      "type": "blocks"
    },
    "imagen_principal": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "galeria": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "video_url": {
      "type": "string"
    },
    "resumen": {
      "type": "text"
    },
    "pdf": {
      "type": "component",
      "repeatable": true,
      "component": "compartido.documento"
    }
  }
}