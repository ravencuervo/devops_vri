{
    "kind": "collectionType",
    "collectionName": "miembro_equipos",
    "info": {
        "singularName": "miembro-equipo",
        "pluralName": "miembro-equipos",
        "displayName": "Equipo VRI",
        "description": "Integrantes de las oficinas y dependencias del VRI"
    },
    "options": {
