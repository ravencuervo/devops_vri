        "orden": {
            "type": "integer",
            "default": 0
        },
        "foto": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "oficina": {
            "type": "enumeration",
            "enum": [
                "Nivel Directivo",
                "TI",
                "Instituto Investigación",
                "Repositorio",
                "Revistas",
                "Gestión Investigación",
                "Ética"
            ],
            "required": true
        },
        "color_clase": {
            "type": "enumeration",
            "enum": [
                "bg-[#030D4F]",
                "bg-[#051675]"
